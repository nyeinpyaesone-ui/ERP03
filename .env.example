# ERP_SOLUTION SOLUTION — Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://erp:erp_secret@localhost:5432/erp_solution
# Production: postgresql://user:pass@host:5432/dbname

# ============================================
# REDIS CACHE
# ============================================
REDIS_URL=redis://localhost:6379/0
# Production: redis://user:pass@host:6379/0

# ============================================
# SECURITY
# ============================================
SECRET_KEY=change-this-to-a-256-bit-random-string
# Generate: openssl rand -hex 32

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:19006
# Production: https://yourdomain.com,https://app.yourdomain.com

# ============================================
# AI / LLM
# ============================================
OLLAMA_URL=http://localhost:11434
# Alternative: https://api.openai.com/v1

OPENAI_API_KEY=sk-your-openai-key
# Required for GPT-4 features

# ============================================
# FILE STORAGE
# ============================================
STORAGE_TYPE=local
# Options: local, s3, minio

AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_BUCKET_NAME=your-bucket
AWS_REGION=ap-southeast-1

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
ENVIRONMENT=development
# Options: development, staging, production

# ============================================
# EMAIL
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================
# MOBILE
# ============================================
EXPO_PROJECT_ID=your-expo-project-id
EAS_BUILD_PROFILE=development
